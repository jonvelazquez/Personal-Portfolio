        </div>

        <div class="timeline-step">
          <h3>Phase III</h3>
          <p class="container-text">Mission Software Development</p>
        </div>
      </div>

      <div class="timeline-grid bottom-row">
        <div class="timeline-step">
          <h3>Phase IV</h3>
          <p class="container-text">Deployment & Hardening</p>
        </div>

        <div class="timeline-step">
          <h3>Phase V</h3>
          <p class="container-text">Continuous Monitoring & Defense</p>
        </div>
      </div>
