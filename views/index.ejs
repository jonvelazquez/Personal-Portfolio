        </div>

        <div class="capability">
          <h3>Space Systems Integration</h3>
          <p class="container-text">Telemetry pipelines, orbital data processing, and resilient comms.</p>
        </div>

        <div class="capability">
          <h3>Mission Software</h3>
          <p class="container-text">Full‑stack systems for aerospace, defense, and secure operations.</p>
        </div>

        <div class="capability">
          <h3>Secure DevOps</h3>
          <p class="container-text">CI/CD automation, container security, and zero‑trust pipelines.</p>
        </div>
      </div>
    </section>

    <div class="mission-divider"></div>

    <!-- ============================
     MISSION WORKFLOW
============================ -->
