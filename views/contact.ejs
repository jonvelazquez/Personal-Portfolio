<%- include('partials/header') %>

<section class="contact-hero mission-panel">
  <h1 class="contact-title">Contact Mission Control</h1>
  <p class="contact-subtitle">
    Submit your information securely. Your message will be logged into our mission database.
  </p>
</section>
<div class="mission-divider contact-divider"></div>

<section class="contact-form-section mission-panel">
  <div class="contact-form-wrapper">
    <form action="/thanks" method="POST" class="contact-form">

      <div class="form-group">
        <label for="firstName">First Name</label>
        <input id="firstName" name="firstName" type="text" required>
      </div>

      <div class="form-group">
        <label for="lastName">Last Name</label>
        <input id="lastName" name="lastName" type="text" required>
      </div>

      <div class="form-group">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required>
      </div>

      <div class="contact-actions">
        <button type="submit" class="btn contact-btn">Submit</button>
      </div>

    </form>
  </div>
</section>

<%- include('partials/footer') %>
